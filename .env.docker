# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=vnstock
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=vnstock_tracker

# ── NextAuth ────────────────────────────────────────────────────────────────
# Tạo secret: openssl rand -base64 32
NEXTAUTH_SECRET=change_this_to_random_secret
NEXTAUTH_URL=http://localhost:3000

# ── Lưu ý ──────────────────────────────────────────────────────────────────
# DATABASE_URL được tự động build từ POSTGRES_* trong docker-compose.yml
# VNSTOCK_API_KEY và OPENROUTER_API_KEY: mỗi user tự nhập trong Settings
