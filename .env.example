# ── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string. Các lựa chọn:
#
# 1. Local PostgreSQL:
#    DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/vnstock_tracker"
#
# 2. Neon (free serverless): https://neon.tech
#    DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
#
# 3. Supabase (free tier): https://supabase.com
#    DATABASE_URL="postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres"
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/vnstock_tracker"

# ── NextAuth ───────────────────────────────────────────────────────────────
# Tạo secret ngẫu nhiên: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"
# URL public của app (local hoặc production)
NEXTAUTH_URL="http://localhost:3000"

# ── App defaults ───────────────────────────────────────────────────────────
DEFAULT_SOURCE=VCI
DEFAULT_INTERVAL=1D
DEFAULT_LOOKBACK_DAYS=180

# ── Lưu ý ─────────────────────────────────────────────────────────────────
# VNSTOCK_API_KEY và OPENROUTER_API_KEY KHÔNG set ở đây.
# Mỗi user tự nhập key cá nhân trong Settings sau khi đăng nhập.

# ── Turso Edge Cache ──────────────────────────────────────────────────────
# Sử dụng để làm bộ đệm đám mây tránh rate limit và cache data nhanh
TURSO_DATABASE_URL="libsql://your-database-slug.turso.io"
TURSO_AUTH_TOKEN="your-turso-jwt-auth-token"
